---
// Component imports
import Button from "@/components/ui/Button.astro";
import ThemeSwitch from "@/components/ui/ThemeSwitch.astro";
---

<aside id="sidebar">
  <div class="layout">
    <h2>My documents</h2>

    <!-- Add new document -->
    <Button text="+ New Document" id="new-document-button" />

    <!-- Document list -->
    <ul class="document-list">
      <template id="document-list-item-template">
        <li class="document-list-item">
          <button type="button" class="document-list-button">
            <svg
              class="document-list-button-icon"
              aria-hidden="true"
              viewBox="0 0 14 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M13.1071 3.39286C13.2738 3.55952 13.4167 3.78571 13.5357 4.07143C13.6548 4.35714 13.7143 4.61905 13.7143 4.85714V15.1429C13.7143 15.381 13.631 15.5833 13.4643 15.75C13.2976 15.9167 13.0952 16 12.8571 16H0.857143C0.619048 16 0.416667 15.9167 0.25 15.75C0.0833333 15.5833 0 15.381 0 15.1429V0.857143C0 0.619048 0.0833333 0.416667 0.25 0.25C0.416667 0.0833333 0.619048 0 0.857143 0H8.85714C9.09524 0 9.35714 0.0595238 9.64286 0.178571C9.92857 0.297619 10.1548 0.440476 10.3214 0.607143L13.1071 3.39286ZM9.14286 1.21429V4.57143H12.5C12.4405 4.39881 12.375 4.27679 12.3036 4.20536L9.50893 1.41071C9.4375 1.33929 9.31548 1.27381 9.14286 1.21429ZM12.5714 5.71429V14.8571H1.14286V1.14286H8V4.85714C8 5.09524 8.08333 5.29762 8.25 5.46429C8.41667 5.63095 8.61905 5.71429 8.85714 5.71429H12.5714Z"
                fill="white"></path>
            </svg>
            <p class="document-list-button-time"></p>
            <p class="document-list-button-name"></p>
          </button>
        </li>
      </template>
    </ul>

    <!-- Theme switch -->
    <ThemeSwitch />
  </div>
</aside>

<style is:global lang="scss">
  #sidebar {
    min-height: 0;
    background-color: var(--bg-container-sidebar);
    padding-inline: var(--pad-cont-sidebar-inline);
    padding-block: var(--pad-cont-sidebar-block);
    overflow: clip;

    .layout {
      height: 100%;
      display: grid;
      grid-template-rows: auto auto 1fr auto;
    }

    h2 {
      font: var(--font-9);
      text-transform: uppercase;
      letter-spacing: var(--ls-9);
      color: var(--fg-text-muted);
      margin-block-end: var(--space-cont-xl);
    }

    .document-list {
      display: grid;
      align-content: start;
      gap: var(--space-cont-lg);
      margin-block: var(--space-cont-lg);
      list-style: none;
      overflow-x: clip;
      overflow-y: auto;

      .status {
        display: flex;
        gap: var(--space-cont-sm);

        svg {
          width: var(--size-svg-spinner);

          @media (prefers-reduced-motion: no-preference) {
            display: block;
            animation: spinner 1.5s steps(12) infinite;
          }
        }

        p {
          font: var(--font-6);
        }
      }

      &-button {
        width: 100%;
        display: grid;
        grid-template-columns: auto 1fr;
        justify-items: start;
        align-items: center;
        column-gap: var(--space-cont-sm);
        background-color: transparent;
        border: none;
        cursor: pointer;
        text-decoration: none;

        &[aria-current="true"] .document-list-button-name {
          color: var(--fg-text-highlight);
        }

        @media (hover: hover) {
          &:hover {
            .document-list-button-name {
              color: var(--fg-text-highlight);
            }
          }
        }

        &-icon {
          width: var(--size-svg-document);
          grid-row: span 2;
        }

        &-time {
          font: var(--font-11);
          color: var(--fg-text-muted);
        }

        &-name {
          font: var(--font-6);
          color: var(--fg-text-neutral);
          text-align: start;
          transition: color var(--trans-fast-out);
        }
      }
    }
  }

  @keyframes spinner {
    to {
      rotate: 360deg;
    }
  }
</style>
