---
// Component imports
import MainHeader from "./MainHeader.astro";
import Markdown from "./Markdown.astro";
import Preview from "./Preview.astro";
---

<main id="main">
  <MainHeader />
  <div class="editor">
    <Markdown />
    <Preview />
  </div>
</main>

<style lang="scss">
  #main {
    min-height: 0;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
  }

  .editor {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }
</style>
