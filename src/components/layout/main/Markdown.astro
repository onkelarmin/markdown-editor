---

---

<section class="markdown" aria-labelledby="markdown-title">
  <!-- Header -->
  <header class="markdown-header">
    <h2 id="markdown-title">Markdown</h2>
  </header>
  <label for="markdown-body" class="visually-hidden">Markdown content</label>

  <!-- Body -->
  <div class="markdown-body">
    <textarea class="markdown-content" id="markdown-content"></textarea>
  </div>
</section>

<style lang="scss">
  @use "../../../sass/miscellaneous/" as *;

  :global(.editor[data-view="markdown"]) .markdown {
    display: grid;
  }

  :global(.editor[data-view="preview"]) .markdown {
    display: none;
  }

  .markdown {
    min-height: 0;
    grid-template-rows: auto 1fr;
    overflow: clip;

    @include mq(medium) {
      border-right: var(--border-editor);
    }

    &-header {
      font: var(--font-9);
      letter-spacing: var(--ls-9);
      color: var(--fg-text-base);
      text-transform: uppercase;
      background-color: var(--bg-container-editor-header);
      padding-inline: var(--pad-cont-editor-header-inline);
      padding-block: var(--pad-cont-editor-header-block);
    }

    &-content {
      width: 100%;
      height: 100%;
      resize: none;
      border: none;
      font: var(--font-10);
      color: var(--fg-text-markdown);
      caret-color: var(--fg-text-highlight);
      background-color: var(--bg-canvas-default);
      padding-inline-start: var(--pad-cont-markdown-inline);
      padding-inline-end: max(
        var(--pad-cont-markdown-inline),
        calc(100% - 45rem - 2 * var(--pad-cont-markdown-inline))
      );
      padding-block: var(--pad-cont-markdown-block);

      &:focus {
        outline: 0px solid transparent;
      }
    }
  }
</style>
