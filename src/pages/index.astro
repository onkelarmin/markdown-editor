---
// Import Site data
import { sitePages } from "@/data/siteData";

// Layout import
import MainLayout from "@layouts/MainLayout.astro";

// Component imports
import Main from "@/components/layout/main/Main.astro";
import Sidebar from "@/components/layout/sidebar/Sidebar.astro";
import SkipNavLink from "@/components/layout/SkipNavLink.astro";
import Toast from "@/components/ui/Toast.astro";
import SignInModal from "@/components/ui/SignInModal.astro";

const page = sitePages.home;

const initialAuth =
  Astro.locals.session && Astro.locals.user
    ? {
        status: "authenticated" as const,
        userId: Astro.locals.user.id,
        email: Astro.locals.user.email,
      }
    : { status: "guest" as const, userId: null, email: null };
---

<MainLayout
  title={page.title}
  description={page.description}
  ogImage={page.ogImage}
>
  <SkipNavLink href="#sidebar" name="documents" />
  <h1 class="visually-hidden">Markdown Editor</h1>

  <div id="app-layout">
    <Sidebar />
    <Main />
    <Toast />
    <!-- Sign-in modal -->
    <SignInModal />
  </div>

  <!-- Auth state -->
  <script
    id="initial-auth"
    type="application/json"
    set:html={JSON.stringify(initialAuth)}
  />
</MainLayout>

<style lang="scss">
  #app-layout {
    height: 100dvh;
    display: grid;
    grid-template-columns: var(--size-misc-sidebar-width) 100%;
    transform: translateX(calc(var(--size-misc-sidebar-width) * -1));
    transition: transform var(--trans-default-out-sensitive);

    &[data-open="true"] {
      transform: translateX(0);
    }
  }
</style>
